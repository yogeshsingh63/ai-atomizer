# Prism AI — Backend Environment Variables
# Copy this file to `.env` and fill in the values for local development.
# In production (Render), set these in the Render dashboard.

# === Database ===
# Local dev (SQLite): sqlite+aiosqlite:///./app.db
# Production (Supabase): postgresql+asyncpg://USER:PASS@HOST:PORT/DBNAME
DATABASE_URL=sqlite+aiosqlite:///./app.db

# === Storage paths ===
# Local dev: relative paths
# Production (Render disk mounted at /data):
#   UPLOAD_DIR=/data/uploads
#   GENERATED_DIR=/data/generated
UPLOAD_DIR=./uploads
GENERATED_DIR=./generated

# === LLM API Keys (all optional — pipeline uses whatever's set) ===
# Get free keys from:
#   NVIDIA:  https://build.nvidia.com/
#   Gemini:  https://aistudio.google.com/apikey
#   OpenRouter: https://openrouter.ai/keys
#   Groq:    https://console.groq.com/keys
#   HF:      https://huggingface.co/settings/tokens
#   AssemblyAI: https://www.assemblyai.com/dashboard/sign-in
NVIDIA_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
HF_API_KEY=
ASSEMBLYAI_API_KEY=

# === Critic Model (used for the rewrite pass) ===
# Strong free model. Falls back to meta/llama-3.3-70b-instruct if invalid.
CRITIC_MODEL=meta/llama-3.3-70b-instruct

# === Whisper Provider ===
# "local" (faster-whisper) | "assemblyai" | "groq" | "openai"
WHISPER_PROVIDER=groq

# === Auth ===
# JWT secret (generate a random string for production)
JWT_SECRET=change-me-in-production

# === CORS ===
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=
