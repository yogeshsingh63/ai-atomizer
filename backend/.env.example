# Prism AI — Backend Environment Variables
# Copy this file to `.env` and fill in the values for local development.
# In production (Render), set these in the Render dashboard.

# === Database ===
# Local dev (SQLite): sqlite+aiosqlite:///./app.db
# Production (Supabase): postgresql+asyncpg://USER:PASS@HOST:PORT/DBNAME
DATABASE_URL=sqlite+aiosqlite:///./app.db

# === Storage paths ===
# Local dev: relative paths
# Production (Render disk mounted at /data):
#   UPLOAD_DIR=/data/uploads
#   GENERATED_DIR=/data/generated
UPLOAD_DIR=./uploads
GENERATED_DIR=./generated

# === LLM API Keys (all optional — pipeline uses whatever's set) ===
# Get free keys from:
#   NVIDIA:  https://build.nvidia.com/
#   Gemini:  https://aistudio.google.com/apikey
#   OpenRouter: https://openrouter.ai/keys
#   Groq:    https://console.groq.com/keys
#   HF:      https://huggingface.co/settings/tokens
#   AssemblyAI: https://www.assemblyai.com/dashboard/sign-in
NVIDIA_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
HF_API_KEY=
ASSEMBLYAI_API_KEY=

# === Critic Model (used for the rewrite pass) ===
# Strong free model. Falls back to meta/llama-3.3-70b-instruct if invalid.
CRITIC_MODEL=meta/llama-3.3-70b-instruct

# === Whisper Provider ===
# "local" (faster-whisper) | "assemblyai" | "groq" | "openai"
WHISPER_PROVIDER=groq

# === YouTube Download (yt-dlp) ===
# YouTube blocks datacenter IPs (Render, Heroku) with bot verification.
# Fix options (in order of reliability):
#   1. Upload cookies.txt to /data/cookies.txt (export from a signed-in browser
#      using a "Get cookies.txt" extension)
#   2. Set YOUTUBE_PROXY to a residential/mobile proxy URL
#   3. Use file upload instead of YouTube URL (always works)
YOUTUBE_PROXY=
YOUTUBE_COOKIES_FILE=

# === Auth ===
# JWT secret — MUST be 32+ bytes for HS256 (PyJWT warns otherwise).
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=prism-ai-super-secret-jwt-signing-key-change-me

# === Google OAuth Configuration ===
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
# For local dev: http://localhost:8000/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# Redirect back to the frontend after auth
CLIENT_REDIRECT_URI=http://localhost:3000

# === CORS ===
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=
